<Window x:Class="WebPhotoshopDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Web Photoshop Desktop"
        Width="1280"
        Height="800"
        MinWidth="860"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#5b5b5b"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Icon="Assets/AppIcon.ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid"
          ClipToBounds="True"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          Background="#5b5b5b"
          SnapsToDevicePixels="True">
        <Border BorderThickness="1"
                BorderBrush="#5f5f5f"
                Background="#474747"
                SnapsToDevicePixels="True">
            <wv2:WebView2 x:Name="EditorWebView"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          DefaultBackgroundColor="#474747" />
        </Border>

        <Grid x:Name="SplashOverlay"
              Background="#3f3f3f"
              Panel.ZIndex="1000"
              IsHitTestVisible="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Height="36"
                  VerticalAlignment="Top"
                  Background="Transparent"
                  MouseLeftButtonDown="OnSplashTitleBarMouseLeftButtonDown"
                  Panel.ZIndex="2">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Height="36">
                    <Button Width="46"
                            Height="36"
                            Padding="0"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="#dcdcdc"
                            FontSize="18"
                            Content="−"
                            ToolTip="Свернуть"
                            Click="OnSplashMinimizeClick" />
                    <Button x:Name="SplashMaximizeButton"
                            Width="46"
                            Height="36"
                            Padding="0"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="#dcdcdc"
                            FontSize="15"
                            Content="□"
                            ToolTip="Развернуть"
                            Click="OnSplashMaximizeClick" />
                    <Button Width="46"
                            Height="36"
                            Padding="0"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="#dcdcdc"
                            FontSize="18"
                            Content="×"
                            ToolTip="Закрыть"
                            Click="OnSplashCloseClick" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,-24,0,0">
                <Image Source="Assets/AppIcon.png"
                       Width="118"
                       Height="118"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" />

                <TextBlock Text="WEB PHOTOSHOP DESKTOP"
                           Margin="0,22,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#e7e7e7"
                           FontSize="24"
                           FontWeight="SemiBold" />

                <TextBlock Text="Photopea Offline"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Center"
                           Foreground="#bdbdbd"
                           FontSize="14" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,0,0,0"
                  VerticalAlignment="Bottom">
                <TextBlock x:Name="SplashStatusText"
                           Text="Запуск WebView2..."
                           Margin="8,0,8,5"
                           VerticalAlignment="Bottom"
                           Foreground="#ffd800"
                           FontSize="12" />

                <Border Height="3"
                        VerticalAlignment="Bottom"
                        Background="#202020">
                    <Grid x:Name="SplashProgressTrack"
                          ClipToBounds="True"
                          SizeChanged="OnSplashProgressTrackSizeChanged">
                        <Border x:Name="SplashProgressFill"
                                Width="0"
                                HorizontalAlignment="Left"
                                Background="#ffd800" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
