<Window x:Class="WebPhotoshopDesktop.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Width="470"
        Height="285"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#3f3f3f"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        Icon="Assets/AppIcon.ico">
    <Border BorderThickness="1"
            BorderBrush="#646464"
            Background="#3f3f3f"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#484848"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <TextBlock Text="Доступно обновление"
                           VerticalAlignment="Center"
                           Margin="12,0,52,0"
                           Foreground="#dddddd"
                           FontSize="13" />

                <Button Width="42"
                        Height="34"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="#dddddd"
                        HorizontalAlignment="Right"
                        FontSize="18"
                        Content="×"
                        ToolTip="Закрыть"
                        Click="OnCloseClick">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#c42b1c" />
                                    <Setter Property="Foreground" Value="#ffffff" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#8f1d13" />
                                    <Setter Property="Foreground" Value="#ffffff" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="20,18,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="Assets/AppIcon.png"
                       Width="48"
                       Height="48"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Новая версия Web Photoshop Desktop готова к установке."
                               Foreground="#eeeeee"
                               FontSize="15"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="VersionText"
                               Margin="0,10,0,0"
                               Foreground="#ffd800"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <TextBlock x:Name="AssetText"
                               Margin="0,6,0,0"
                               Foreground="#cfcfcf"
                               FontSize="12"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Сохрани текущий проект перед установкой обновления."
                               Margin="0,12,0,0"
                               Foreground="#bdbdbd"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#303030"
                    Background="#454545">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                    <Button x:Name="DownloadButton"
                            Width="132"
                            Height="32"
                            Margin="0,0,8,0"
                            Content="Скачать setup"
                            Click="OnDownloadClick" />
                    <Button Width="86"
                            Height="32"
                            Content="Позже"
                            Click="OnCloseClick" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
